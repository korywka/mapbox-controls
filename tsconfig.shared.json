{
	"compilerOptions": {
		"strict": true,
		"checkJs": true,
		"allowJs": true,
		"declaration": true,
		"emitDeclarationOnly": true,
		"esModuleInterop": true,
		"removeComments": true,
		"skipLibCheck": true,
		"rootDir": "${configDir}/src",
		"outDir": "${configDir}/types",
		"lib": ["dom", "esnext"],
	},
	"include": ["${configDir}/src"],
}
